{
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "CleanSweep Connect",
        "supportEmail": "support@cleansweepcleaningcompany.com",
        "authorizedRedirectUris": [
          "https://connect.cleansweepcleaningcompany.com",
          "https://www.connect.cleansweepcleaningcompany.com"
        ]
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "apphosting": {
    "backendId": "cleansweep-connect",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ]
  }
}
